<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="SeleniumTestSuite">
    <test name="SampleTest">
        <parameter name="website title" value="Example Domains"/>
        <classes>
            <class name="SimpleTest"/>
        </classes>
    </test>

    <test name="SampleTest2">
        <parameter name="website title" value="Wrong text"/>
        <classes>
            <class name="SimpleTest"/>
        </classes>
    </test>

    <!-- Specify the output directory -->
    <parameter name="output-directory" value="test-output"/>
</suite>